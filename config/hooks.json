{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'REPO_DIR/scripts/hooks/block-destructive.sh'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "'REPO_DIR/scripts/hooks/warn-no-tests.sh'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'REPO_DIR/scripts/hooks/verify-tests.sh'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "'REPO_DIR/scripts/hooks/lint-on-save.sh'",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "'REPO_DIR/scripts/hooks/doc-drift-check.sh'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
